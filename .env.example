# =========================================================================
# SciNanoAI — environment template
# Copy to `.env`, fill in real values, NEVER commit the resulting file.
# =========================================================================

# --- PyTorch build for the Docker images: `cpu` (default) or `gpu` (CUDA 13).
# `cpu` skips ~4 GB of nvidia-* wheels and builds in a couple of minutes.
# Switch to `gpu` only on a CUDA host (and add GPU reservations to compose).
# Changing this requires a rebuild: `docker compose build`.
TORCH_VARIANT=cpu

# --- LLM (single OpenAI-compatible gateway: LiteLLM / OpenRouter / vLLM)
# The gateway resolves LLM_MODEL to its real upstream (OpenRouter / YandexGPT /
# GigaChat / Ollama / ...), so the bot needs only these three values.
LLM_MODEL=openrouter/openai/gpt-oss-120b
LLM_BASE_URL=http://litellm-gateway:4000/v1
LLM_API_KEY=

# --- Vector service
VECTOR_SERVICE_URL=http://localhost:8000
VECTOR_DB_PATH=db/intfloat_multilingual-e5-large
VECTOR_EMBEDDING_MODEL=intfloat/multilingual-e5-large
VECTOR_SERVICE_API_KEY=

# --- Cellpose model
CELLPOSE_MODEL_PATH=models/cellpose_v0_1/cellpose_full_stream_filtred
IMAGE_UM_PER_PX=0.6451612903225806

# --- S3 (Yandex Cloud Object Storage) — used by scripts/s3.py
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# --- Gradio basic auth (chatbot UI)
GRADIO_USERNAME=
GRADIO_PASSWORD=
