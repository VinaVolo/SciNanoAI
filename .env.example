# =========================================================================
# SciNanoAI — environment template
# Copy to `.env`, fill in real values, NEVER commit the resulting file.
# =========================================================================

# --- LLM provider: pick a model name, the matching credentials are read below
# Supported values: gpt-oss:latest | YandexGPT4 | GigaChat-Pro | <openai-model>
LLM_MODEL=gpt-oss:latest

# --- OpenAI-compatible provider (required for OpenAI models)
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1

# --- YandexGPT
YANDEX_API_KEY=
YANDEX_API_BASE=

# --- GigaChat / Sber
SBER_API_KEY=

# --- Local Ollama / gpt-oss provider (required if LLM_MODEL=gpt-oss:latest)
LOCAL_API_KEY=
LOCAL_API_BASE=http://ollama.lab:11434/api/chat

# --- Vector service
VECTOR_SERVICE_URL=http://localhost:8000
VECTOR_DB_PATH=db/intfloat_multilingual-e5-large
VECTOR_EMBEDDING_MODEL=intfloat/multilingual-e5-large
VECTOR_SERVICE_API_KEY=

# --- Cellpose model
CELLPOSE_MODEL_PATH=models/cellpose_v0_1/cellpose_full_stream_filtred
IMAGE_UM_PER_PX=0.6451612903225806

# --- S3 (Yandex Cloud Object Storage) — used by scripts/s3.py
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# --- Gradio basic auth (chatbot UI)
GRADIO_USERNAME=
GRADIO_PASSWORD=
